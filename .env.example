PRIZMA_BASE_URL=http://localhost:8000
PRIZMA_ENVIRONMENT=dev
PRIZMA_LOG_LEVEL=INFO
PRIZMA_EXECUTION_MODE=broker
PRIZMA_STORAGE_BACKEND=s3
PRIZMA_INFERENCE_BACKEND=local
PRIZMA_ARTIFACT_BUCKET=prizma-artifacts
PRIZMA_S3_ENDPOINT_URL=http://minio:9000
PRIZMA_S3_ACCESS_KEY_ID=minioadmin
PRIZMA_S3_SECRET_ACCESS_KEY=minioadmin123
PRIZMA_RABBITMQ_URL=amqp://prizma:prizma@rabbitmq:5672/%2f
PRIZMA_RABBITMQ_QUEUE=prizma.jobs
PRIZMA_JOB_STATE_DIR=/app/state/jobs
PRIZMA_LOCAL_ARTIFACT_DIR=/app/state/local-artifacts
PRIZMA_TRITON_URL=triton:8000
PRIZMA_TRITON_MODEL_NAME=prizma_stylizer
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
