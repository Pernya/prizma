        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(prizma_http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(prizma_http_requests_total[5m])), 1)",
          "refId": "A"
        }
      ],
      "title": "Error Rate",
      "type": "timeseries"
    },
    {
